### 3. `controllers/liveController.js`

```js
const mockService = require('../services/mockService');

const liveController = {
	getLiveStatus: (req, res) => {
		res.json({
			code: 0,
			message: 'success',
			data: {
				status: mockService.live.status,          // 'online' | 'offline'
				current_stream: mockService.live.currentStream
			}
		});
	},

	startLive: (req, res) => {
		const { stream_id } = req.body;

		if (!stream_id) {
			return res.status(400).json({
				code: -1,
				message: 'stream_id 不能为空',
				data: null
			});
		}

		// 标记当前直播流
		mockService.live.status = 'online';
		mockService.live.currentStream = stream_id;

		// 这里直接给一个可播放的测试 HLS 地址
		const playHls = 'https://test-streams.mux.dev/x36xhzz/x36xhzz.m3u8';

		res.json({
			code: 0,
			message: '直播已开始',
			data: {
				stream_id,
				play_hls: playHls
			}
		});
	},

	stopLive: (req, res) => {
		mockService.live.status = 'offline';
		mockService.live.currentStream = null;

		res.json({
			code: 0,
			message: '直播已停止',
			data: null
		});
	},

	getViewersCount: (req, res) => {
		// 简单 mock 一个人数
		const viewers = Math.floor(Math.random() * 100);

		res.json({
			code: 0,
			message: 'success',
			data: {
				viewers
			}
		});
	}
};

module.exports = liveController;
```

