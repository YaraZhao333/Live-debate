### 6. `services/mockService.js`

只给你关键结构，其他已有的保持不动即可：

```js
const mockService = {
	// 直播流相关
	streams: (() => {
		let streams = [
			{
				id: 'mock-stream-1',
				name: '默认直播流 1',
				url: 'https://example.com/live/mock-stream-1.m3u8',
				enabled: true,
				created_at: Date.now()
			},
			{
				id: 'mock-stream-2',
				name: '默认直播流 2',
				url: 'https://example.com/live/mock-stream-2.m3u8',
				enabled: true,
				created_at: Date.now()
			}
		];

		return {
			getAll: () => streams,
			getById: id => streams.find(s => s.id === id),
			create: data => {
				const newStream = {
					id: 'stream-' + Date.now(),
					enabled: true,
					created_at: Date.now(),
					...data
				};
				streams.push(newStream);
				return newStream;
			},
			update: (id, data) => {
				const idx = streams.findIndex(s => s.id === id);
				if (idx === -1) return null;
				streams[idx] = { ...streams[idx], ...data };
				return streams[idx];
			},
			delete: id => {
				const idx = streams.findIndex(s => s.id === id);
				if (idx === -1) return false;
				streams.splice(idx, 1);
				return true;
			},
			toggleEnabled: id => {
				const stream = streams.find(s => s.id === id);
				if (!stream) return null;
				stream.enabled = !stream.enabled;
				return stream;
			}
		};
	})(),

	// 直播状态
	live: {
		status: 'offline',      // 'online' | 'offline'
		currentStream: null
	},

	// 辩题（给 debate-topic 用）
	debate: {
		get: () => ({
			id: 'debate-1',
			title: '如果有一个能一键消除痛苦的按钮，你会按吗？',
			sideA: '会按',
			sideB: '不会按'
		})
	}

	// 其他原来就有的模块（votes / ai / ...）保持不变
};

module.exports = mockService;
```

