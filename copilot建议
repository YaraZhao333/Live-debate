### 3. 真正需要补齐的：各个 controller 用 mockService 实现

你现在的 routes 已经很完整了，比如 `adminRoutes.js`：

```js
router.get('/admin/debate', adminController.getDebateSettings);
router.put('/admin/debate', adminController.updateDebateSettings);
router.get('/admin/users', adminController.getUsers);
router.get('/admin/users/:id', adminController.getUserById);
router.get('/admin/dashboard', adminController.getDashboard);
```

**要做的就是：写一个“纯 mock 的 adminController”，只依赖 `mockService`。**

#### 3.1 示例：`controllers/adminController.js`

```js
// src/controllers/adminController.js
const mockService = require('../services/mockService');

module.exports = {
  // 获取辩题设置
  getDebateSettings: (req, res) => {
    const debate = mockService.debate.get();
    res.json({
      success: true,
      data: debate
    });
  },

  // 更新辩题设置
  updateDebateSettings: (req, res) => {
    const { title, description, leftPosition, rightPosition } = req.body;
    const updated = mockService.debate.update({
      title,
      description,
      leftPosition,
      rightPosition
    });
    res.json({
      success: true,
      data: updated
    });
  },

  // 获取用户列表
  getUsers: (req, res) => {
    const users = mockService.users.getAll();
    res.json({
      success: true,
      data: users
    });
  },

  // 获取单个用户
  getUserById: (req, res) => {
    const user = mockService.users.getById(req.params.id);
    if (!user) {
      return res.status(404).json({ success: false, message: '用户不存在' });
    }
    res.json({ success: true, data: user });
  },

  // 仪表盘数据
  getDashboard: (req, res) => {
    const dashboard = mockService.statistics.getDashboard();
    res.json({
      success: true,
      data: dashboard
    });
  }
};
```

这样一来，**admin 相关接口就完全是 mock 的、可独立运行的**。

