{
  "version": 2,
  "name": "live-debate-system",
  "builds": [
    {
      "src": "gateway/gateway.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "gateway/gateway.js"
    },
    {
      "src": "/admin/(.*)",
      "dest": "gateway/gateway.js"
    },
    {
      "src": "/static/(.*)",
      "dest": "gateway/gateway.js"
    },
    {
      "src": "/ws",
      "dest": "gateway/gateway.js"
    },
    {
      "src": "/(.*)",
      "dest": "gateway/gateway.js"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "BACKEND_PORT": "8081",
    "PORT": "8080"
  }
}
